{
    "name": "@mdl-systems/cocoro-sdk",
    "version": "1.0.0",
    "description": "TypeScript SDK for cocoro-core — Personality AI Operating System",
    "author": "MDL Systems",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest",
        "test:run": "vitest run",
        "type-check": "tsc --noEmit",
        "type-check:all": "tsc --noEmit -p tsconfig.test.json",
        "lint": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "cocoro",
        "ai",
        "personality",
        "sdk",
        "typescript",
        "llm",
        "agent"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/mdl-systems/cocoro-sdk.git"
    },
    "homepage": "https://github.com/mdl-systems/cocoro-sdk#readme",
    "bugs": {
        "url": "https://github.com/mdl-systems/cocoro-sdk/issues"
    },
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.3.0",
        "vitest": "^1.2.0",
        "@types/node": "^20.0.0"
    }
}