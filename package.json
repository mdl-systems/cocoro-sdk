{
    "name": "@mdl-systems/cocoro-sdk",
    "version": "0.1.0",
    "description": "TypeScript SDK for cocoro-core API",
    "author": "MDL Systems",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest",
        "test:run": "vitest run",
        "type-check": "tsc --noEmit",
        "type-check:all": "tsc --noEmit -p tsconfig.test.json",
        "lint": "tsc --noEmit"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.3.0",
        "vitest": "^1.2.0",
        "@types/node": "^20.0.0"
    }
}